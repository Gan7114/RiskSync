# DeFiStressOracle — Environment Setup
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Your Wallet ──────────────────────────────────────────────────────────────
# Use a DEDICATED deployment wallet. Never use your main wallet here.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
# Get a free key from https://alchemy.com or https://infura.io
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY_HERE
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY_HERE

# ─── Deployed Contract Addresses (filled after running Deploy.s.sol) ──────────
ASSET_REGISTRY_ADDRESS=
MULTI_ASSET_ROUTER_ADDRESS=
MCO_ADDRESS=
TDRV_ADDRESS=
CPLCS_ADDRESS=
TCO_ADDRESS=
URC_ADDRESS=
CIRCUIT_BREAKER_ADDRESS=
STRESS_REGISTRY_ADDRESS=
ARU_ADDRESS=
CCRB_ADDRESS=

# ─── Optional Multi-Asset Pool/Feed Overrides (for Deploy*.s.sol) ───────────
# If these are unset, scripts still register BTC/LINK/AAVE as disabled assets.
BTC_UNI_POOL=
BTC_USD_FEED=
BTC_TOKEN1_DECIMALS=6

LINK_UNI_POOL=
LINK_USD_FEED=
LINK_TOKEN1_DECIMALS=18

AAVE_UNI_POOL=
AAVE_USD_FEED=
AAVE_TOKEN1_DECIMALS=18

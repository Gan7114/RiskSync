# DeFiStressOracle — Environment Setup
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Your Wallet ──────────────────────────────────────────────────────────────
# Use a DEDICATED deployment wallet. Never use your main wallet here.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
# Get a free key from https://alchemy.com or https://infura.io
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY_HERE
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY_HERE

# ─── Deployed Contract Addresses (filled after running Deploy.s.sol) ──────────
MCO_ADDRESS=
TDRV_ADDRESS=
CPLCS_ADDRESS=
TCO_ADDRESS=
URC_ADDRESS=
CIRCUIT_BREAKER_ADDRESS=
STRESS_REGISTRY_ADDRESS=
